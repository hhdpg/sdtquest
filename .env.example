# 钉钉智能问答机器人 — 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ── 钉钉配置 ──
DINGTALK_APP_KEY=your_app_key_here
DINGTALK_APP_SECRET=your_app_secret_here
DINGTALK_BOT_CODE=your_bot_code_here

# ── Ollama 配置 (可选,有默认值) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:35b-a3b-instruct-4bit
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_TIMEOUT=120
OLLAMA_MAX_CONCURRENT=2

# ── RAG 配置 (可选,有默认值) ──
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=knowledge_base
RAG_TOP_K=5
RAG_THRESHOLD_STANDARD=0.8
RAG_THRESHOLD_FLEXIBLE=0.6

# ── 生成参数 (可选,有默认值) ──
LLM_TEMPERATURE_STANDARD=0.3
LLM_TEMPERATURE_FLEXIBLE=0.7
LLM_MAX_TOKENS=2048
LLM_CONTEXT_WINDOW=8192

# ── 数据库 (可选,有默认值) ──
ANALYTICS_DB_PATH=./data/analytics.db

# ── 代码解析 (可选,有默认值) ──
PARSER_DEFAULT_PROJECT_ROOT=

# ── 会话配置 (可选,有默认值) ──
SESSION_MAX_HISTORY=10
SESSION_TTL_SECONDS=300

# ── 限流配置 (可选,有默认值) ──
RATE_LIMIT_PER_USER=60
MAX_QUEUE_SIZE=100

# ── 应用配置 (可选,有默认值) ──
APP_NAME=dingtalk-qa-bot
APP_ENV=development
LOG_LEVEL=INFO
